PORT=3001
NODE_ENV=development

# 数据库
# 本地开发（Mongo 内存库，无需安装 MongoDB）
USE_MEMORY_DB=true
MONGODB_URI=mongodb://127.0.0.1:27017/collabmatch

# Coze 部署：平台注入 PostgreSQL（Supabase），自动使用 postgres 驱动
# DB_DRIVER=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# USE_MEMORY_DB=false
# PG_SSL=true

# JWT（生产务必更换，≥16 字符）
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# 认证：dev | production | auto（auto=有短信配置则用短信，否则开发码）
AUTH_MODE=auto
DEV_AUTH_CODE=123456
SMS_CODE_TTL_SEC=300
SMS_RESEND_INTERVAL_SEC=60

# 腾讯云短信（登录验证码）https://console.cloud.tencent.com/smsv2
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# 文件存储：inline | cos | auto（auto=有 COS 配置则走 COS）
FILE_STORAGE=auto
MAX_FILE_BYTES_INLINE=2097152
MAX_FILE_BYTES_COS=52428800

# 腾讯云 COS https://console.cloud.tencent.com/cos
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=your-bucket-1250000000
COS_REGION=ap-guangzhou
COS_PREFIX=collabmatch
# 可选 CDN 域名，如 https://cdn.example.com
COS_PUBLIC_BASE_URL=

# 豆包 / 火山方舟（留空则本地模拟 AI）
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-pro-32k
DOUBAO_VISION_MODEL=doubao-1-5-vision-pro-32k
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

SEED_ON_START=true
