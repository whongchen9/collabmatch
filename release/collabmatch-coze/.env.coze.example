# Coze 控制台环境变量示例（复制到平台配置，勿提交真实密钥）

NODE_ENV=production
PORT=8080

# 数据库（Coze 平台通常自动注入 DATABASE_URL）
USE_MEMORY_DB=false
DB_DRIVER=postgres
PG_SSL=true
SEED_ON_START=true

# 必填：生产随机串，至少 16 位
JWT_SECRET=请替换为随机长字符串
JWT_EXPIRES_IN=7d

# 认证：未配置腾讯云短信前用开发验证码；上线后改 production 并填短信项
AUTH_MODE=auto
DEV_AUTH_CODE=123456

# AI（可选，留空则使用内置模拟回复）
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-pro-32k
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 文件（可选，配置 COS 后大文件走对象存储）
FILE_STORAGE=auto

# 腾讯云短信（AUTH_MODE=production 时必填）
# TENCENT_SMS_SECRET_ID=
# TENCENT_SMS_SECRET_KEY=
# TENCENT_SMS_SDK_APP_ID=
# TENCENT_SMS_SIGN_NAME=
# TENCENT_SMS_TEMPLATE_ID=

# 腾讯云 COS（可选）
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=ap-guangzhou
